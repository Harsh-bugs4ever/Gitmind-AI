# GitMind Backend — Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (required for AI features)
GEMINI_API_KEY=AIza...

# Optional: Gemini model override
GEMINI_MODEL=gemini-2.0-flash

# Auth signing secret (use a long random value)
AUTH_SECRET_KEY=replace_with_long_random_secret

# GitHub OAuth App credentials
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback
FRONTEND_AUTH_SUCCESS_URL=http://localhost:5173/auth/callback

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/gitmind

# GitHub Personal Access Token (used to validate webhook signatures)
GITHUB_TOKEN=ghp_...

# Optional: GitHub Webhook Secret (for HMAC signature validation)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Server settings (optional, used by uvicorn start scripts)
HOST=0.0.0.0
PORT=8000
